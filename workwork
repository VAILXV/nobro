local function apply_mode_change(newMode)
    if not newMode then return end
    CONFIG.MODE = newMode
    BADGE_TARGET = CONFIG.MODE
    selectedMode = newMode
    selectedHold = get_mode_hold(newMode)

    local usesDistance = (newMode == 'SHOOTING2' or newMode == 'SHOOTING3' or newMode == 'PLAYMAKING')
    if usesDistance then
        local dist = get_active_distance(newMode)
        if dist ~= nil then
            selectedDistance = dist
        else
            selectedDistance = (CONFIG.DISTANCES and CONFIG.DISTANCES[newMode]) or selectedDistance
        end
        LIVE_DIST[newMode] = selectedDistance
    end

    local panel = ensure_mode_gui()
    if not panel then return end

    local dropdownBtn = panel:FindFirstChild('DropdownBtn')
    if dropdownBtn then
        dropdownBtn.Text = tostring(newMode) .. '  ▾'
    end

    local distDropdown = panel:FindFirstChild('DistDropdown')
    local distOptions = panel:FindFirstChild('DistOptions')
    if distDropdown then
        distDropdown.Visible = usesDistance
        if usesDistance then
            distDropdown.Text = ('Dist: %s  ▾'):format(tostring(selectedDistance))
        end
    end
    if distOptions and not usesDistance then
        distOptions.Visible = false
    end

    local timingDrop = panel:FindFirstChild('TimingDropdown')
    if timingDrop then
        timingDrop.Text = ('Timer: %.2fs  ▾'):format(tonumber(selectedHold))
    end

    local toastLabel = panel:FindFirstChild('Toast')
    if toastLabel then
        toastLabel.Text = ('Mode auto-set: %s'):format(tostring(newMode))
        task.delay(1.2, function()
            if toastLabel and toastLabel.Parent then
                toastLabel.Text = ''
            end
        end)
    end
end

