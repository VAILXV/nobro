local function tween_position(part, distance)
    local root_position = root_part.Position
    local part_position = part.Position

    local target_position = Vector3.new(part_position.X, root_position.Y, part_position.Z)
    local target_distance = Vector3.zero

    local backward = -part.CFrame.LookVector

    if distance then
        target_distance = -backward * distance
    end

    local distance_to_travel = (root_position - target_position).Magnitude
    local time = distance_to_travel / TWEEN_SETTINGS.SPEED

    local tween_info = TweenInfo.new(time, Enum.EasingStyle[TWEEN_SETTINGS.STYLE], Enum.EasingDirection[TWEEN_SETTINGS.DIRECTION])

    local tween = tween_service:Create(root_part, tween_info, {
        CFrame = distance and CFrame.lookAt(target_position + target_distance, target_position)
    })

    tween:Play(); tween.Completed:Wait()
end

