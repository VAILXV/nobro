local function track_multi_mode_finishing_rep(mode)
    if mode ~= `FINISHING` then return end
    if not (MULTI_MODE_STATE.active and MULTI_MODE_STATE.seqType == 'counts') then return end

    local goal = MULTI_MODE_STATE.goal or 0
    if goal <= 0 then return end

    local now = os.clock()
    local last = MULTI_MODE_STATE.lastTick or 0
    if last > 0 and (now - last) < 0.75 then
        return
    end

    MULTI_MODE_STATE.lastTick = now
    MULTI_MODE_STATE.count = math.min(goal, (MULTI_MODE_STATE.count or 0) + 1)

    if MULTI_MODE_STATE.count < goal then
        set_status(string.format('Multi-mode FINISHING reps: %d / %d', MULTI_MODE_STATE.count, goal))
        return
    end

    local preset = MULTI_MODE_STATE.preset or {}
    MULTI_MODE_STATE.active = false
    MULTI_MODE_STATE.seqType = nil
    MULTI_MODE_STATE.goal = nil
    MULTI_MODE_STATE.count = 0
    MULTI_MODE_STATE.lastTick = 0
    MULTI_MODE_STATE.preset = nil

    if preset.second then
        apply_mode_change(preset.second)
        set_status(('Multi-mode sequence: switched to %s'):format(tostring(preset.second)))
    end
end

