-- Wait until we're within maxDist studs of a target Instance/Vector3 (or until timeout seconds elapse)
local function wait_until_near(target, maxDist, timeout)
    local function getPos()
        if typeof(target) == "Instance" then
            return target and target.Position or root_part.Position
        else
            return target
        end
    end

    local start = tick()
    while true do
        local p = getPos()
        local d = (root_part.Position - Vector3.new(p.X, root_part.Position.Y, p.Z)).Magnitude
        if d <= (maxDist or 4) then return true end
        if timeout and (tick() - start) >= timeout then return false end
        task.wait()
    end
end

-- Wait until within `radius` and remain there for `stableFor` seconds; overall timeout ends with false
local function wait_until_stable_near(target, radius, stableFor, timeout)
    radius = radius or 2.8
    stableFor = stableFor or 0.15
    local function getPos()
        if typeof(target) == "Instance" then
            return target and target.Position or root_part.Position
        else
            return target
        end
    end

    local start = tick()
    local stableStart = nil
    while true do
        local p = getPos()
        local d = (root_part.Position - Vector3.new(p.X, root_part.Position.Y, p.Z)).Magnitude
        local near = d <= radius
        if near then
            stableStart = stableStart or tick()
            if (tick() - stableStart) >= (stableFor or 0.15) then
                return true
            end
        else
            stableStart = nil
        end
        if timeout and (tick() - start) >= timeout then return false end
        task.wait()
    end
end

