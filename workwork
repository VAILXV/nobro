-- Gameplay activity tracking to avoid rejoin during active play
local LAST_ACTIVITY_T = os.clock()
local SAFE_REJOIN_IDLE_SEC = 2.5 -- seconds without input/game action before we consider it safe to rejoin

local function mark_activity()
    LAST_ACTIVITY_T = os.clock()
end

local function recently_active()
    return (os.clock() - (LAST_ACTIVITY_T or 0)) < SAFE_REJOIN_IDLE_SEC
end

local function safe_to_rejoin()
    return (not CRITICAL_ACTION) and (not recently_active())
end

