-- Wait for the local player's data/attributes to be initialized (menu/lobby often need this)
local function wait_for_player_loaded(timeout)
    local deadline = os.clock() + (timeout or 12)
    local okLoaded, okData = false, false
    local player_data = nil
    -- Try to get PlayerData tree early if present
    pcall(function()
        player_data = local_player:FindFirstChild('PlayerData') or local_player:WaitForChild('PlayerData', 8)
    end)
    while os.clock() < deadline do
        -- Attributes path
        local aLoaded = local_player:GetAttribute('Loaded')
        local aData = local_player:GetAttribute('LoadedData')
        okLoaded = (aLoaded == true)
        okData = (aData == true)
        -- Fallback: some games set flags inside PlayerData as BoolValues
        if player_data then
            local pdLoaded = player_data:FindFirstChild('Loaded')
            local pdData = player_data:FindFirstChild('LoadedData')
            if pdLoaded and pdLoaded:IsA('BoolValue') and pdLoaded.Value then okLoaded = true end
            if pdData and pdData:IsA('BoolValue') and pdData.Value then okData = true end
        end
        if okLoaded and okData then return true end
        task.wait(0.25)
    end
    return okLoaded and okData
end

-- High-precision wait using Heartbeat to avoid task.wait jitter for timing-sensitive holds
local function precise_wait(seconds)
    seconds = tonumber(seconds) or 0
    if seconds <= 0 then return end
    local rs = game:GetService('RunService')
    local start = os.clock()
    while (os.clock() - start) < seconds do
        rs.Heartbeat:Wait()
    end
end

