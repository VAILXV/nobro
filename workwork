-- Auto rejoin via GuiService error hook: route disconnect prompts straight to the Main Menu with retries
do
    local gs = game:GetService('GuiService')
    local menu_place_id = 18474291382 -- main menu / build select
    local MAX_ATTEMPTS = tonumber(CONFIG.RECONNECT and CONFIG.RECONNECT.ERROR_MAX_ATTEMPTS) or 0
    local BASE_DELAY = tonumber(CONFIG.RECONNECT and CONFIG.RECONNECT.ERROR_BASE_DELAY) or 1

    local function attempt_menu_rejoin(reason, message)
        if menu_rejoin_state.active then return end
        if PENDING_TELEPORT then return end
        if not (CONFIG.RECONNECT and CONFIG.RECONNECT.AUTO_REJOIN) then return end

        ERROR_TRIGGER_ACTIVE = true
        menu_rejoin_state.active = true
        menu_rejoin_state.attempts = 0

        task.spawn(function()
            local teleport_requested = false
            local attempt_limit = (MAX_ATTEMPTS and MAX_ATTEMPTS > 0) and MAX_ATTEMPTS or nil
            while (not attempt_limit) or (menu_rejoin_state.attempts < attempt_limit) do
                if PENDING_TELEPORT then break end
                menu_rejoin_state.attempts += 1
                local attempt = menu_rejoin_state.attempts
                local denomLabel = attempt_limit and tostring(attempt_limit) or '∞'

                task.wait(0.5)
                local lp = players.LocalPlayer
                if not lp then break end

                set_status(string.format('Auto rejoin → Menu (%d/%s)…', attempt, denomLabel))
                local ok, err = pcall(function()
                    teleport_service:Teleport(menu_place_id, lp)
                end)
                if ok then
                    debug_log('reconnect', 'Menu teleport requested (attempt '..attempt..')', reason, message)
                    teleport_requested = true
                    break
                else
                    debug_log('reconnect', 'Menu teleport attempt '..attempt..' failed:', tostring(err))
                    local delay = BASE_DELAY * (2 ^ (attempt - 1))
                    if delay > 60 then delay = 60 end
                    task.wait(delay)
                end
            end

            menu_rejoin_state.active = false
            if teleport_requested then
                set_status('Auto rejoin → Menu requested…')
            elseif not PENDING_TELEPORT then
                if attempt_limit and menu_rejoin_state.attempts >= attempt_limit then
                    set_status('Auto rejoin → Menu failed: max attempts reached')
                    ERROR_TRIGGER_ACTIVE = false
                else
                    set_status('Auto rejoin → Menu waiting…')
                end
            end
        end)
    end

    request_menu_rejoin = function(reason)
        attempt_menu_rejoin(reason or 'manual', nil)
    end

    if gs and gs.ErrorMessageChanged then
        gs.ErrorMessageChanged:Connect(function()
            local msg = ''
            pcall(function()
                if gs.GetErrorMessage then
                    msg = gs:GetErrorMessage() or ''
                end
            end)
            if msg ~= '' then
                debug_log('reconnect', 'GuiService error prompt:', msg)
                attempt_menu_rejoin('GuiService', msg)
            end
        end)
    end
end

