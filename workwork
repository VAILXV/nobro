-- Lightweight auto-rejoin/watchdog system
do
    local rs = game:GetService('RunService')
    local ts = teleport_service
    local backoffs = (CONFIG.RECONNECT and CONFIG.RECONNECT.RETRY_BACKOFF) or {2,4,8,16}
    local rejoin_state = { inProgress = false, started = false }

    -- Best-effort fast rejoin (same place). Uses Roblox matchmaking to pick an instance.
    local function fast_rejoin(reason)
        if not (CONFIG.RECONNECT and CONFIG.RECONNECT.AUTO_REJOIN) then return end
        if rejoin_state.inProgress then return end
        if not safe_to_rejoin() then
            debug_log('reconnect', 'Fast rejoin deferred (not safe):', tostring(reason))
            -- Retry shortly after the activity window
            task.delay(3, function()
                if not rejoin_state.inProgress then
                    fast_rejoin((tostring(reason) or 'unknown')..':deferred')
                end
            end)
            return
        end
        rejoin_state.inProgress = true
        debug_log('reconnect', 'Fast rejoin start:', tostring(reason))

        local attempt = 0
        local function try_once()
            attempt += 1
            local ok, err = pcall(function()
                -- Prefer reconnecting to the same instance if possible (mirrors the Reconnect button)
                if job_id and #tostring(job_id) > 0 and attempt <= 2 then
                    ts:TeleportToPlaceInstance(place_id, job_id, local_player)
                else
                    ts:Teleport(place_id, local_player) -- let Roblox pick an available server
                end
            end)
            if not ok then
                debug_log('reconnect', 'Teleport error:', tostring(err))
                local delay = backoffs[math.min(attempt, #backoffs)] or 10
                task.delay(delay, try_once)
            end
        end

        try_once()
    end
    trigger_fast_rejoin = fast_rejoin

    -- Mark in-progress when a teleport begins (prevents duplicate rejoin attempts)
    pcall(function()
        if players.LocalPlayer and players.LocalPlayer.OnTeleport then
            players.LocalPlayer.OnTeleport:Connect(function(state)
                if state == Enum.TeleportState.InProgress then
                    rejoin_state.inProgress = true
                    -- Clear safety flag once a teleport actually starts
                    SAFETY_NET_ACTIVE = false
                    -- Mark that a teleport is underway so we expect a place/job change soon
                    PENDING_TELEPORT = true
                end
            end)
        end
    end)

    -- Retry if a teleport initialization fails (e.g., server full)
    pcall(function()
        ts.TeleportInitFailed:Connect(function(player, result, errMsg)
            if player ~= local_player then return end
            debug_log('reconnect', 'Teleport failed:', tostring(result), tostring(errMsg))
            -- Allow another attempt shortly
            rejoin_state.inProgress = false

            -- If the safety net was attempting a menu teleport, fallback to the lobby instead of generic rejoin
            if SAFETY_NET_ACTIVE then
                SAFETY_NET_ACTIVE = false
                pcall(function()
                    teleport_service:Teleport(18517963950, local_player) -- matchmaking lobby fallback
                end)
                return
            end

            -- If an error-driven reconnect is active, keep hammering Menu/Lobby using the error loop
            if ERROR_TRIGGER_ACTIVE then
                task.delay(1.0, function()
                    if request_menu_rejoin then
                        request_menu_rejoin('TeleportInitFailed:'..tostring(result))
                    else
                        error_reconnect_loop()
                    end
                end)
            else
                task.delay(1.0, function()
                    fast_rejoin('TeleportInitFailed:'..tostring(result))
                end)
            end
        end)
    end)

    local function start_reconnect_watchdogs()
        if rejoin_state.started then return end
        rejoin_state.started = true

        -- Heartbeat stall watchdog
        task.spawn(function()
            if not (CONFIG.RECONNECT and CONFIG.RECONNECT.HEARTBEAT_WATCHDOG and CONFIG.RECONNECT.HEARTBEAT_WATCHDOG.ENABLED) then return end
            local stalls = 0
            local last = os.clock()
            local thresh = CONFIG.RECONNECT.HEARTBEAT_WATCHDOG.STALL_THRESHOLD or 1.5
            local maxStalls = CONFIG.RECONNECT.HEARTBEAT_WATCHDOG.MAX_STALLS or 4
            rs.Heartbeat:Connect(function()
                local now = os.clock()
                local dt = now - last
                last = now
                if dt > thresh then
                    -- If player is active or in a critical section, do not count this stall toward rejoin
                    if not safe_to_rejoin() then
                        stalls = 0
                        return
                    end
                    stalls += 1
                    debug_log('reconnect', string.format('Heartbeat stall: %.2fs (%d/%d)', dt, stalls, maxStalls))
                    if stalls >= maxStalls then
                        fast_rejoin('Heartbeat stalls')
                        stalls = 0
                    end
                else
                    stalls = 0
                end
            end)
        end)

        -- Ping-change watchdog
        task.spawn(function()
            if not (CONFIG.RECONNECT and CONFIG.RECONNECT.PING_WATCHDOG and CONFIG.RECONNECT.PING_WATCHDOG.ENABLED) then return end
            local timeout = CONFIG.RECONNECT.PING_WATCHDOG.TIMEOUT or 12
            local interval = CONFIG.RECONNECT.PING_WATCHDOG.SAMPLE_INTERVAL or 1
            local lastPing = nil
            local lastChange = os.clock()
            while task.wait(interval) do
                local ok, val = pcall(function()
                    return ping:GetValue()
                end)
                if not ok then
                    -- If Stats access failed consistently, prefer to retry joining
                    if (os.clock() - lastChange) > timeout then
                        if safe_to_rejoin() then
                            fast_rejoin('Ping read failure')
                        else
                            -- treat as activity; reset timer to avoid firing mid-action
                            lastChange = os.clock()
                        end
                    end
                else
                    if lastPing == nil or val ~= lastPing then
                        lastPing = val
                        lastChange = os.clock()
                    else
                        if (os.clock() - lastChange) > timeout then
                            debug_log('reconnect', 'Ping stuck for >', timeout, 's (val=', tostring(val), ')')
                            if safe_to_rejoin() then
                                fast_rejoin('Ping stuck')
                            else
                                -- push the window forward until safe
                                lastChange = os.clock()
                            end
                            lastChange = os.clock() -- avoid repeated triggers
                        end
                    end
                end
            end
        end)
    end

    -- Start the watchdogs early
    start_reconnect_watchdogs()

    -- Robust error-based reconnect loop: alternate Menu/Lobby with backoffs until a teleport starts
    local function error_reconnect_loop()
        if error_rejoin.running then return end
        error_rejoin.running = true
        error_rejoin.attempt = 0
        local originPlace = game.PlaceId
        local backoffs = (CONFIG.RECONNECT and CONFIG.RECONNECT.RETRY_BACKOFF) or {2,4,8,16,30}
        local menuFirst = (CONFIG.RECONNECT and CONFIG.RECONNECT.ERROR_MENU_FIRST ~= false)
        local fbDelay = (CONFIG.RECONNECT and CONFIG.RECONNECT.ERROR_LOBBY_FALLBACK_DELAY) or 2.0

        local function attempt_once()
            if PENDING_TELEPORT then return end
            if game.PlaceId ~= originPlace then error_rejoin.running = false; return end
            error_rejoin.attempt += 1
            local tryMenu = menuFirst
            if error_rejoin.attempt % 2 == 0 then
                -- Alternate destinations on each attempt for stubborn failures
                tryMenu = not menuFirst
            end
            if tryMenu then
                set_status('Reconnect: attempt '..tostring(error_rejoin.attempt)..' → Menu…')
                pcall(function()
                    teleport_service:Teleport(18474291382, local_player)
                end)
                -- Fallback to Lobby if teleport didn't start
                task.delay(fbDelay, function()
                    if error_rejoin.running and (not PENDING_TELEPORT) and game.PlaceId == originPlace then
                        set_status('Reconnect: fallback → Lobby…')
                        pcall(function()
                            teleport_service:Teleport(18517963950, local_player)
                        end)
                    end
                end)
            else
                set_status('Reconnect: attempt '..tostring(error_rejoin.attempt)..' → Lobby…')
                pcall(function()
                    teleport_service:Teleport(18517963950, local_player)
                end)
                task.delay(fbDelay, function()
                    if error_rejoin.running and (not PENDING_TELEPORT) and game.PlaceId == originPlace then
                        set_status('Reconnect: fallback → Menu…')
                        pcall(function()
                            teleport_service:Teleport(18474291382, local_player)
                        end)
                    end
                end)
            end

            local delay = backoffs[math.min(error_rejoin.attempt, #backoffs)] or 10
            task.delay(delay, function()
                if error_rejoin.running and (not PENDING_TELEPORT) and game.PlaceId == originPlace then
                    attempt_once()
                end
            end)
        end

        attempt_once()
    end
    trigger_error_reconnect = function()
        ERROR_TRIGGER_ACTIVE = true
        error_reconnect_loop()
    end
end

-- Reset the safety timer when we actually land in a different server instance
task.spawn(function()
    while task.wait(1) do
        local curPlace = game.PlaceId
        local curJob = game.JobId
        if curPlace ~= LAST_PLACE_ID or curJob ~= LAST_JOB_ID then
            LAST_PLACE_ID = curPlace
            LAST_JOB_ID = curJob
            SERVER_JOIN_TIME = tick()
            PENDING_TELEPORT = false
            ERROR_TRIGGER_ACTIVE = false
            error_rejoin.running = false
            menu_rejoin_state.active = false
            menu_rejoin_state.attempts = 0
        end
    end
end)

-- Safety watchdog: if we're stuck in the same place too long, force a Menu reset then resume normally.
task.spawn(function()
    local minutes = (CONFIG and CONFIG.SAFETY and CONFIG.SAFETY.MENU_TIMEOUT_MIN) or 7
    local LIMIT = math.max(1, minutes) * 60 -- seconds
    while task.wait(5) do
        local elapsed = tick() - SERVER_JOIN_TIME
        if elapsed >= LIMIT then
            safety_net_teleport()
            break
        end
    end
end)

