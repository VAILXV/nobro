local function start_server_timer()
    task.spawn(function()
        while true do
            local gui = ensure_server_timer_gui()
            local label = gui and gui:FindFirstChild('TimerLabel')
            if label then
                local t = workspace.DistributedGameTime
                if type(t) ~= 'number' then t = 0 end
                if t < 0 then t = 0 end
                local hours = math.floor(t / 3600)
                local minutes = math.floor(t / 60) % 60
                local seconds = math.floor(t) % 60
                label.Text = string.format("%02d:%02d:%02d", hours, minutes, seconds)

                local info = label:FindFirstChild('InfoLabel')
                if info then
                    local ms = math.floor(get_ping_ms())
                    local mode = (CONFIG and CONFIG.MODE) or '?'
                    local role = get_role_text()
                    -- Only show Dist for modes where it's actually used (not for layups/defense)
                    if mode == 'SHOOTING2' or mode == 'SHOOTING3' or mode == 'PLAYMAKING' then
                        local dist = get_active_distance(mode)
                        if dist ~= nil then
                            info.Text = string.format("Role: %s  |  Mode: %s  |  Dist: %s  |  Ping: %d ms", tostring(role), tostring(mode), tostring(dist), ms)
                        else
                            info.Text = string.format("Role: %s  |  Mode: %s  |  Ping: %d ms", tostring(role), tostring(mode), ms)
                        end
                    else
                        info.Text = string.format("Role: %s  |  Mode: %s  |  Ping: %d ms", tostring(role), tostring(mode), ms)
                    end
                end

                -- Keep the Mode panel's role tag in sync too
                local pg = local_player:FindFirstChild('PlayerGui')
                local root = pg and pg:FindFirstChild('ServerTimerGui')
                local panel = root and root:FindFirstChild('ModePanel')
                local roleTag = panel and panel:FindFirstChild('RoleTag')
                if roleTag then
                    roleTag.Text = 'Role: ' .. get_role_text()
                end

                -- Auto-layout: if Mode panel is present/visible, move timer near bottom to avoid overlap
                if panel and panel.Visible ~= false then
                    if label.AnchorPoint.Y ~= 1 or label.Position.Y.Scale ~= 0.98 then
                        label.AnchorPoint = Vector2.new(0.5, 1)
                        label.Position = UDim2.new(0.5, 0, 0.98, 0)
                        label.Size = UDim2.new(0, 320, 0, 64)
                    end
                else
                    if label.AnchorPoint.Y ~= 0.5 or label.Position.Y.Scale ~= 0.5 then
                        label.AnchorPoint = Vector2.new(0.5, 0.5)
                        label.Position = UDim2.new(0.5, 0, 0.5, 0)
                        label.Size = UDim2.new(0, 320, 0, 80)
                    end
                end
            end
            task.wait(1)
        end
    end)
end

