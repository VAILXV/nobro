-- Helper: get nearest valid ball from map.Balls (returns a BasePart)
local function get_nearest_ball(map)
    local balls = map:FindFirstChild('Balls')
    if not balls then return nil end

    local function part_for(inst)
        if inst:IsA('BasePart') then return inst end
        if inst:IsA('Model') then
            if inst.PrimaryPart then return inst.PrimaryPart end
            local p = inst:FindFirstChildWhichIsA('BasePart', true)
            if p then return p end
        end
        return nil
    end

    local nearest, best = nil, math.huge
    for _, child in ipairs(balls:GetChildren()) do
        local part = part_for(child)
        if part then
            local d = (root_part.Position - part.Position).Magnitude
            if d < best then
                best = d
                nearest = part
            end
        end
    end
    return nearest
end

