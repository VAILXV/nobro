-- Shared time-based sync helper for coordinating actions across main/alt without custom remotes
local sync_state = { last = -1 }
local function should_sync_fire()
    if not (CONFIG.SYNC and CONFIG.SYNC.ENABLED) then return true end
    local interval = (CONFIG.SYNC.INTERVAL or 0.5)
    if interval <= 0 then return true end
    local offset = (CONFIG.SYNC.OFFSET or 0)
    local t = workspace.DistributedGameTime or 0
    local idx = math.floor((t - offset) / interval)
    if idx <= (sync_state.last or -1) then return false end
    local phase = (t - offset) % interval
    local rem = interval - phase
    local window = (CONFIG.SYNC.WINDOW or 0.05) + (get_ping_ms() / 1000) * (CONFIG.SYNC.PING_FACTOR or 0.5)
    -- Fire near the end of the beat (rem <= window) OR right after the beat (phase <= window)
    if rem <= window or phase <= window then
        sync_state.last = idx
        return true
    end
    return false
end

