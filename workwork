                if alt_shot_done then alt_shot_done = false end
            end

            -- If not in PLAYMAKING, still position at the shooting spot even off-ball
            if CONFIG.MODE ~= `PLAYMAKING` then
                tween_position(goal, 70)
                continue
            end

            -- PLAYMAKING: hover near main and reach
            if CONFIG.MODE == `PLAYMAKING` then
                tween_position(main_account_root_part, 5)
                -- Reach immediately (no sync gating) to mirror fixedplay behavior
                mark_activity()
                action_remote:FireServer({
                    Action = `Reach`;
                    Reach = true;
                })
            end

            continue
        elseif not players:FindFirstChild(account_two.USER_NAME) then
            -- Alt/opponent left: ensure we can finish the game by scoring a quick mid with green timing
            if not has_ball(character) then
                local balls = map:WaitForChild(`Balls`)
                local kids = balls:GetChildren()
                local ball = kids[2] or kids[1]
                if ball then
                    move_to(ball)
                end
                continue
            end

            -- Use a fixed/default mid distance (do not use live override) just to end the game
            local dist = (CONFIG.DISTANCES and CONFIG.DISTANCES.SHOOTING2) or 25
            tween_position(goal, dist)
            -- Force a one-time green release regardless of CONFIG.TIMING
            shoot_with_hold(0.4)
            continue
        end

        if not has_ball(character) then
            local balls = map:WaitForChild(`Balls`)
            local ball = balls:GetChildren()[2] -- already a ball for some reason but we need the second one

            if not ball then
                continue
            end

            move_to(ball); continue
        end

        if character:GetAttribute(`Action`) == `Shooting` then
            continue
        end

        -- Determine target distance from CONFIG for the active mode
        local mode = CONFIG.MODE
        local distances = CONFIG.DISTANCES

        if mode == `FINISHING` or mode == `DEFENDING` then
            -- Exact fixedplay FINISHING/DEFENDING behavior: sprint + hold forward, no pre-steps
            -- Mark critical section so reconnects don't interrupt the layup
            CRITICAL_ACTION = true
            sprint(true)
            move_to(goal)

            -- Keep forward held toward the hoop during the approach (fixedplay pattern)
            local rs = game:GetService('RunService')
            local conn; conn = rs.RenderStepped:Connect(function()
                local dir = (goal.Position - root_part.Position)
                if dir.Magnitude > 0 then
                    local_player:Move(dir.Unit)
                else
                    local_player:Move(Vector3.zero)
                end
            end)

            -- Wait until close enough to register a layup, then shoot while still sprinting/holding forward
            wait_until_near(goal, 3, 2) -- within ~3 studs or up to 2s
            shoot()

            -- Stop holding forward right after the release and end sprint
            if conn then conn:Disconnect() end
            sprint(false)

            -- Cancel any remaining walk target
            move_to(Vector3.zero)
            CRITICAL_ACTION = false
            track_multi_mode_finishing_rep(mode)
        elseif mode == `SHOOTING2` or mode == `SHOOTING3` then
            CRITICAL_ACTION = true
            mark_activity()
            local dist = (mode == `SHOOTING3`) and (get_active_distance('SHOOTING3') or distances.SHOOTING3)
                or (get_active_distance('SHOOTING2') or distances.SHOOTING2)
            tween_position(goal, dist)
            shoot()
            CRITICAL_ACTION = false
        elseif mode == `PLAYMAKING` then
            local pdist = get_active_distance('PLAYMAKING') or distances.PLAYMAKING
            tween_position(goal, pdist)
            -- Dribble calls are now spammed by the background spammer; keep branch lightweight
        end
    end
end
